{
  "expo": {
    "name": "Paddles Up",
    "slug": "paddles-up",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pickleballapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "privacy": "https://dawsonhanks.github.io/paddles-up-privacy/",
    "ios": {
      "supportsTablet": true,
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      },
      "config": {
        "googleMapsApiKey": "AIzaSyDIIfA-IG2_eHBlXx0kw92T1Gvox8XcoM4"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Paddles Up to use your location to find courts near you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5b08d659-3160-45f5-b63f-3ecd0fe3eddc"
      }
    },
    "owner": "dawsonhanks"
  }
}
